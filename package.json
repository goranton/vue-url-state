{
  "name": "@goranton/vue-url-state",
  "version": "0.1.0",
  "description": "Type-safe URL query state management for Vue and Nuxt",
  "keywords": [
    "vue",
    "nuxt",
    "vue-router",
    "query",
    "url-state",
    "query-state",
    "typescript",
    "filters"
  ],
  "license": "MIT",
  "author": "Anton Gor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goranton/vue-url-state.git"
  },
  "bugs": {
    "url": "https://github.com/goranton/vue-url-state/issues"
  },
  "homepage": "https://github.com/goranton/vue-url-state#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:core": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "build": "tsup",
    "smoke:package": "node scripts/smoke-package.mjs",
    "check:package": "npm run build && npm run smoke:package",
    "pack:dry-run": "npm pack --dry-run",
    "check": "npm run typecheck && npm run test && npm run check:package && npm run pack:dry-run",
    "prepack": "npm run build",
    "playground": "npm --prefix playground run dev",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  }
}
